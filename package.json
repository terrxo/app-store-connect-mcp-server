{
  "name": "appstore-connect-mcp-server",
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "build": "tsc && shx chmod +x dist/src/*.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/bundle.cjs && shx chmod +x dist/bundle.cjs",
    "start": "node dist/src/index.js"
  },
  "bin": {
    "appstore-connect-mcp": "./dist/src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "axios": "^1.6.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^18.0.0",
    "esbuild": "^0.24.0",
    "shx": "^0.3.4",
    "typescript": "^5.6.2"
  }
}
